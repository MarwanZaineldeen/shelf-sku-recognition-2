# ==============================================================================
# RETAIL AI PLATFORM — ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. REMOTE MACHINE PORT ASSIGNMENTS
# ------------------------------------------------------------------------------
# Public port mapped to Nginx reverse proxy (Web UI and API proxy)
FRONTEND_PORT=80

# Public port mapped directly to FastAPI backend service
BACKEND_PORT=5000

# Port mapped to Grafana dashboard interface
GRAFANA_PORT=3001

# ------------------------------------------------------------------------------
# 2. DOCKER REGISTRY SETTINGS
# ------------------------------------------------------------------------------
# Docker Hub account or organization name for image pulls
DOCKERHUB_USERNAME=mazen1393
IMAGE_TAG=latest

# ------------------------------------------------------------------------------
# 3. BACKEND SERVICE PARAMETERS
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=5000
RETAIL_AI_ROOT=.

# ------------------------------------------------------------------------------
# 4. MODEL WEIGHTS & DATABASE PERSISTENT PATHS
# ------------------------------------------------------------------------------
# SQLite vector registry database path
REGISTRY_DB_PATH=data/processed/crops/gt_clean/retail_sku_registry_dinov3.db

# Dynamic SKU onboarding database path
ONBOARDING_DB_PATH=data/processed/crops/gt_clean/retail_sku_registry_onboarding.db

# Active Learning HITL review database path
REVIEWS_DB_PATH=data/processed/active_learning/reviews.db

# YOLOv8 object detection model weights path
YOLO_WEIGHTS_PATH=runs/detect/yolo8l_sku110k/yolov8l-sku110k.pt

# SKU commercial metadata mapping JSON path
SKU_MAPPING_PATH=configs/sku_mapping.json

# SKU thumbnail preview directory
SKU_PREVIEW_DIR=data/processed/Sku Preview

# HuggingFace & PyTorch model cache paths
HF_HOME=.cache/huggingface
TORCH_HOME=.cache/torch
